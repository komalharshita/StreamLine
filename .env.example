# StreamLine Backend Configuration Example

# FastAPI Settings
PROJECT_NAME="StreamLine"
ENVIRONMENT="development"
LOG_LEVEL="info"
API_V1_STR="/api/v1"
HOST="0.0.0.0"
PORT=8000

# Google Cloud Settings
GOOGLE_CLOUD_PROJECT="streamline-ai-saas"
# Path to local credentials JSON file (if running locally without gcloud login)
GOOGLE_APPLICATION_CREDENTIALS=""
GCS_BUCKET_NAME="streamline-data-ingestion"
BIGQUERY_DATASET="streamline_analytics"

# Gemini API Settings
GEMINI_API_KEY="your-gemini-api-key-here"

# Firebase Authentication Settings
FIREBASE_PROJECT_ID="streamline-auth"
# Set to false in production to enforce signature validation
FIREBASE_MOCK_AUTH="true"

# Next.js Frontend Settings
NEXT_PUBLIC_API_URL="http://localhost:8000"

# CORS Allowed Origins (JSON list format)
ALLOWED_ORIGINS='["http://localhost:3000", "https://your-custom-vercel-url.vercel.app"]'


